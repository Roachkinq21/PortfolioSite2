@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Brennon Ary</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>

    <div>
        <h1 class="display-2">Welcome to my Portfolio!</h1>
    </div>
    <div class="container bg-gradient mt-5">
        <p>test</p>
    </div>

    <section id="skills" class="py-section bg-dark-2">
        <div class="container">
            <h2 class="section-title">Skills</h2>
            <div class="row g-4 mt-2">

                <div class="">
                    <h6 class="skill-group-title">Languages</h6>
                    <div class="flex-wrap gap-2 mt-2">
                        <span class="badge skill-badge">C#</span>
                        <span class="badge skill-badge">JavaScript</span>
                        <span class="badge skill-badge">TypeScript</span>
                        <span class="badge skill-badge">SQL</span>
                        <span class="badge skill-badge">HTML/CSS</span>
                    </div>
                </div>

                <div>
                    <h6 class="skill-group-title">Frameworks & Libraries</h6>
                    <div class="flex-wrap gap-2 mt-2">
                        <span class="badge skill-badge">ASP.NET Core</span>
                        <span class="badge skill-badge">Blazor</span>
                        <span class="badge skill-badge">Entity Framework</span>
                        <span class="badge skill-badge">React</span>
                        <span class="badge skill-badge">Bootstrap</span>
                    </div>
                </div>

                <div class="">
                    <h6 class="skill-group-title">Tools & Platforms</h6>
                    <div class="flex-wrap gap-2 mt-2">
                        <span class="badge skill-badge">Azure</span
                        <span class="badge skill-badge">Git</span>
                        <span class="badge skill-badge">SQL Server</span>
                        <span class="badge skill-badge">Visual Studio</span>
                        <span class="badge skill-badge">Eclipse</span>
                        <span class="badge skill-badge">Claude AI</span>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <div class="card text-center text-bg-secondary mt-4">
    <div class="card-header">
    <ul class="nav nav-tabs card-header-tabs">
      <li class="nav-item">
        <a class="nav-link active" aria-current="true" href="#">Active</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="#">Resume</a>
      </li>
      <li class="nav-item">
        <a class="nav-link disabled" aria-disabled="true">Disabled</a>
      </li>
    </ul>
  </div>

  <div class="row g-1 mt-">
    <div class="col-md-2">
    <img src="..." class="img-fluid rounded-start" alt="...">
    </div>

    <div class="col-md-8">
        <div class="card-body">
        <h5 class="card-title d-flex">Special title treatment</h5>
        <p class="card-text d-flex">With supporting text below as a natural lead-in to additional content.</p>
        <div class="d-flex flex-row mb-3">
            <i class="bi bi-envelope btn btn-primary fs-2 me-2"> Email</i>
            <i class="bi bi-telephone btn btn-primary fs-2 me-2"> Phone</i>
        </div>
        </div>
    </div>
  </div>

  
  
</div>


</div>
